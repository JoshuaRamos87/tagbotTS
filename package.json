{
  "name": "dictionary",
  "version": "1.4.0",
  "description": "interfacing with dictionaryapi",
  "main": "tagbot.js",
  "type": "module",
  "scripts": {
    "start-win": "tsc && node ./build/deploy-commands.js && node ./build/tagbot.js",
    "start-linux": "npm run build-linux",
    "build-win": "rimraf build && tsc",
    "run-win": "node ./build/tagbot.js",
    "deploy": "rimraf build && tsc && node ./build/deploy-commands.js",
    "build-linux": "tsc && pm2 start ./build/tagbot.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoshuaRamos87/dictionary.git"
  },
  "keywords": [
    "dictionary"
  ],
  "author": "Joshua Ramos",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/JoshuaRamos87/dictionary/issues"
  },
  "homepage": "https://github.com/JoshuaRamos87/dictionary#readme",
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "better-sqlite3": "^12.9.0",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "ffmpeg-static": "^5.3.0",
    "iqdb-client": "^3.0.0",
    "libsodium-wrappers": "^0.8.3",
    "opusscript": "^0.1.1",
    "typescript": "^6.0.2",
    "youtube-dl-exec": "^3.1.5",
    "youtubei.js": "^17.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2"
  }
}
