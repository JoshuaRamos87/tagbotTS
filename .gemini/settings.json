        "DB_URL": "sqlite:///C:/DEV/tagbotTS/data/database.sqlite"
      }
    },
    "logical-thinking": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    }
  },
  "agents": {
    "directories": ["./.gemini/agents"]
  }
}