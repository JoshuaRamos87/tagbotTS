      "args": [
        "/c",
        "npx",
        "-y", 
        "@modelcontextprotocol/server-sqlite", 
        "C:\\DEV\\tagbotTS\\data\\database.sqlite"
      ]
    },
    "db-toolbox": {
      "command": "cmd",
      "args": [
        "/c",
